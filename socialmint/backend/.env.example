# ── Circle (free signup at console.circle.com) ────────────────────────────────
CIRCLE_API_KEY=TEST_API_KEY_XXXXXXXXXXXXXXXXXXXXXXXX
CIRCLE_WALLET_SET_ID=           # filled after running: npm run setup
CIRCLE_TREASURY_WALLET_ID=      # filled after running: npm run setup
CIRCLE_TREASURY_ADDRESS=        # filled after running: npm run setup

# ── Anthropic (console.anthropic.com) ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── MongoDB (free at mongodb.com/atlas — no credit card needed) ───────────────
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/socialmint

# ── JWT Secret (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))") ──
JWT_SECRET=your_long_random_secret_here

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173
